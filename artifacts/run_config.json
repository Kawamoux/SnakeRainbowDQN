{
  "env": {
    "grid_width": 15,
    "grid_height": 15,
    "cell_size": 32,
    "render_fps": 12,
    "observation_mode": "rich",
    "compact_observation_size": 11,
    "rich_observation_size": 30,
    "action_size": 3,
    "food_reward": 10.0,
    "death_penalty": -20.0,
