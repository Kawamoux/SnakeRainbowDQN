    "deterministic_torch": false,
    "device": "cpu"
  },
  "evaluation": {
    "seed": 42,
    "episodes": 5,
    "render_mode": "human",
    "fps": 12
  },
  "paths": {
    "artifacts_dir": "artifacts",
