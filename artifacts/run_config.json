    "logs_dir": "artifacts/logs",
    "plots_dir": "artifacts/plots",
    "best_model_path": "artifacts/checkpoints/best_model.pt",
    "latest_checkpoint_path": "artifacts/checkpoints/latest_checkpoint.pt",
    "training_metrics_path": "artifacts/logs/training_metrics.csv",
    "training_plot_path": "artifacts/plots/training_curves.png",
